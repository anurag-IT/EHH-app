// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id           Int       @id @default(autoincrement())
  name         String
  email        String    @unique
  uniqueId     String    @unique // EH-XXXXXX
  avatar       String?
  role         String    @default("USER") // USER | ADMIN
  status       String    @default("ACTIVE") // ACTIVE | BANNED | PERMANENT_BAN
  banUntil     DateTime?
  banCount     Int       @default(0)
  banReason    String?
  isRestricted Boolean   @default(false)
  posts        Post[]
  messages     Message[]
  flags        FlaggedContent[] // Content flagged by or related to this user
  likes        Like[]
  comments     Comment[]
}

model Post {
  id              Int             @id @default(autoincrement())
  userId          Int
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  imagePath       String
  caption         String?
  sha256          String
  phash           String?
  ahash           String?
  dhash           String?
  orb             String?
  embedding       String?
  parentId        Int?            // For repost tracking
  hash            String?
  parent          Post?           @relation("Reposts", fields: [parentId], references: [id])
  reposts         Post[]          @relation("Reposts")
  createdAt       DateTime        @default(now())
  flags           FlaggedContent[]
  likes           Like[]
  comments        Comment[]
}

model Like {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    Int
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, postId])
}

model Comment {
  id        Int      @id @default(autoincrement())
  text      String
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    Int
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}


model Message {
  id          Int      @id @default(autoincrement())
  senderId    Int?
  receiverId  Int
  receiver    User     @relation(fields: [receiverId], references: [id], onDelete: Cascade)
  content     String   @default("")
  messageText String?  // Kept for backwards compatibility but we'll use content
  isAnonymous Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model FlaggedContent {
  id        Int      @id @default(autoincrement())
  postId    Int?
  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason    String
  status    String   @default("PENDING") // PENDING | APPROVED | REJECTED
  priority  String   @default("LOW") // LOW | MEDIUM | HIGH
  createdAt DateTime @default(now())
}

model AdminLog {
  id         Int      @id @default(autoincrement())
  actionType String   // ban_user, delete_user, delete_post, global_delete_image, etc.
  adminName  String
  targetId   String?  // ID of the user, post, or original_id affected
  details    String?  // JSON string or description, e.g., "number of deleted posts: 5"
  createdAt  DateTime @default(now())
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}


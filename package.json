{
  "name": "ehh-monorepo",
  "private": true,
  "workspaces": [
    "backend",
    "frontend",
    "mobile"
  ],
  "scripts": {
    "install:all": "npm install",
    "dev:backend": "npm run dev --workspace=backend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:mobile": "npm run start --workspace=mobile",
    "dev": "concurrently -n \"BACKEND,FRONTEND,MOBILE\" -c \"blue,magenta,cyan\" \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:mobile\"",
    "start:all": "npm run dev"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "concurrently": "^9.2.1"
  }
}

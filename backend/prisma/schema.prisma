// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int       @id @default(autoincrement())
  name         String
  email        String    @unique
  uniqueId     String    @unique // EH-XXXXXX
  avatar       String?
  bio          String? @db.Text
  isPrivate    Boolean   @default(false)
  role         String    @default("USER") // USER | ADMIN
  status       String    @default("ACTIVE") // ACTIVE | BANNED | PERMANENT_BAN
  banUntil     DateTime?
  banCount     Int       @default(0)
  banReason    String?
  isRestricted Boolean   @default(false)
  lastSeen    DateTime  @default(now())
  posts        Post[]
  messagesSent     Message[] @relation("SentMessages")
  messagesReceived Message[] @relation("ReceivedMessages")
  flags        FlaggedContent[] // Content flagged by or related to this user
  likes        Like[]
  comments     Comment[]
  notifications Notification[] @relation("UserNotifications")
  followers    UserFollow[] @relation("FollowedBy")
  following    UserFollow[] @relation("Following")
  stories      Story[]
  storyReactions StoryReaction[]
  storyViews     StoryView[]
  storyReplies   StoryReply[]
}

model UserFollow {
  id          Int      @id @default(autoincrement())
  followerId  Int
  follower    User     @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  followingId Int
  following   User     @relation("FollowedBy", fields: [followingId], references: [id], onDelete: Cascade)
  status      String   @default("ACCEPTED") // PENDING | ACCEPTED
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
}

model Post {
  id              Int             @id @default(autoincrement())
  userId          Int
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  imagePath       String
  imageUrl        String?
  imagePaths      String[]        @default([])
  imageUrls       String[]        @default([])
  caption         String?
  phash           String?
  parentId        Int?            // For repost tracking
  parent          Post?           @relation("Reposts", fields: [parentId], references: [id])
  reposts         Post[]          @relation("Reposts")
  createdAt       DateTime        @default(now())
  location        String?
  flags           FlaggedContent[]
  likes           Like[]
  comments        Comment[]

  @@index([userId])
  @@index([createdAt])
  @@index([phash])
  @@index([parentId])
}



model Like {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    Int
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, postId])
  @@index([postId])
  @@index([userId])
  @@index([createdAt])
}

model Comment {
  id        Int      @id @default(autoincrement())
  text      String
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    Int
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([postId])
  @@index([userId])
  @@index([createdAt])
}


model Message {
  id          Int      @id @default(autoincrement())
  senderId    Int
  sender      User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId  Int
  receiver    User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  content     String   @default("")
  messageText String?  // Kept for backwards compatibility 
  isRead      Boolean  @default(false)
  isAnonymous Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
  @@index([receiverId, isRead])
}

model FlaggedContent {
  id        Int      @id @default(autoincrement())
  postId    Int?
  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason    String
  status    String   @default("PENDING") // PENDING | APPROVED | REJECTED
  priority  String   @default("LOW") // LOW | MEDIUM | HIGH
  createdAt DateTime @default(now())
}

model AdminLog {
  id         Int      @id @default(autoincrement())
  actionType String   // ban_user, delete_user, delete_post, global_delete_image, etc.
  adminName  String
  targetId   String?  // ID of the user, post, or original_id affected
  details    String?  // JSON string or description, e.g., "number of deleted posts: 5"
  createdAt  DateTime @default(now())
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Notification {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  senderId    Int?
  senderName  String?
  senderAvatar String?
  type        String   // "LIKE", "COMMENT", "SYSTEM", "FOLLOW_REQUEST"
  postId      Int?
  requestId   Int?
  content     String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([postId])
}

model ImageMatch {
  id              Int      @id @default(autoincrement())
  imageId         Int
  matchedImageId  Int
  similarityScore Float
  matchType       String   @default("HASH_MATCH")
  confidenceLevel String   @default("LOW")
  createdAt       DateTime @default(now())
}

model Story {
  id           Int            @id @default(autoincrement())
  userId       Int
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  imageUrl     String
  imagePath    String
  caption      String?        // text overlay on story
  textColor    String?        // hex color for text overlay
  bgColor      String?        // solid background color (for text-only stories)
  stickers     Json?          // array of {type, content, x, y, scale} objects
  createdAt    DateTime       @default(now())
  expiresAt    DateTime
  reactions    StoryReaction[]
  views        StoryView[]
  replies      StoryReply[]
  @@index([userId])
  @@index([expiresAt])
}

model StoryReaction {
  id        Int      @id @default(autoincrement())
  storyId   Int
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emoji     String   // e.g. "❤️", "😂", "😮", "😢", "🔥", "👏"
  createdAt DateTime @default(now())
  @@unique([storyId, userId])  // one reaction per user per story
}

model StoryView {
  id        Int      @id @default(autoincrement())
  storyId   Int
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  viewedAt  DateTime @default(now())
  @@unique([storyId, userId])
}

model StoryReply {
  id        Int      @id @default(autoincrement())
  storyId   Int
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   String
  createdAt DateTime @default(now())
}

